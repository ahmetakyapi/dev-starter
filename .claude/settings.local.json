{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "Bash(bash scripts/health-check.sh)"
    ],
    "additionalDirectories": [
      "C:\\Old Projects\\dev-starter\\.claude"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/gate-guard.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/quality-scan.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/routemap-sync.sh"
          }
        ]
      }
    ]
  }
}
